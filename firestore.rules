rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
                    && request.auth.uid == userId
                    && request.resource.data.username is string
                    && request.resource.data.username.matches('^[a-z0-9_]{3,12}$')
                    && request.resource.data.displayName == request.resource.data.username;
      
      allow update: if request.auth != null 
                    && request.auth.uid == userId
                    && request.resource.data.username is string
                    && request.resource.data.username.matches('^[a-z0-9_]{3,12}$')
                    && request.resource.data.displayName == request.resource.data.username;
                    
      allow delete: if false; // Profiles are persistent
    }
    
    // Game Statistics (Anti-cheat enforced)
    match /stats/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
                    && request.auth.uid == userId
                    && request.resource.data.wins == 0
                    && request.resource.data.losses == 0
                    && request.resource.data.goals == 0;
                    
      allow update: if request.auth != null 
                    && request.auth.uid == userId
                    // Prevent stats jumps (wins/losses can only increment by at most 1 per update)
                    && request.resource.data.wins >= resource.data.wins
                    && request.resource.data.wins <= resource.data.wins + 1
                    && request.resource.data.losses >= resource.data.losses
                    && request.resource.data.losses <= resource.data.losses + 1
                    && request.resource.data.goals >= resource.data.goals;
                    
      allow delete: if false;
    }
    
    // Match History Logs
    match /history/{matchId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false; // Match logs are immutable
    }
  }
}
